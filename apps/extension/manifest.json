{
  "manifest_version": 3,
  "name": "AudioSync Extension",
  "version": "1.0",
  "description": "Captura de audio de pestañas para AudioSync",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  }
}